# IntentWatch backend environment variables
# Copy to .env and fill values. (.env is ignored by git)

# ---------------- Supabase (optional) ----------------
# Project URL (Settings -> API)
SUPABASE_URL=

# Backend-only key (Settings -> API -> service_role secret)
# NEVER put this in the frontend.
SUPABASE_SERVICE_ROLE_KEY=

# Enable uploading recorded clips to Supabase Storage
INTENTWATCH_HISTORY_UPLOAD_SUPABASE=0

# Supabase Storage bucket name (case-sensitive)
# Example: footages
INTENTWATCH_HISTORY_BUCKET=footages

# Optional: insert metadata rows into this table when upload succeeds
INTENTWATCH_HISTORY_TABLE=footage_clips

# Enable/disable local history recording
INTENTWATCH_HISTORY_ENABLED=1

# Clip rotation seconds
INTENTWATCH_HISTORY_CLIP_SECONDS=60

# History recording codec (FourCC)
# Prefer H.264 for browser playback. Options depend on your OpenCV build / codecs.
# Examples: avc1, H264, X264, mp4v
# INTENTWATCH_HISTORY_FOURCC=avc1,H264,mp4v

# Force legacy mp4v if you need compatibility with a specific tool (not recommended for browsers)
# INTENTWATCH_HISTORY_FORCE_MP4V=0

# ---------------- Smart alert snapshots ----------------
# Save a cropped image whenever key alerts fire (Weapon / Zone / Unattended Bag)
INTENTWATCH_SNAPSHOTS_ENABLED=1

# Upload snapshots to Supabase Storage (uses SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY)
# If enabled, alert payloads may include a public URL (useful for Telegram sendPhoto).
INTENTWATCH_SNAPSHOT_UPLOAD_SUPABASE=0

# Supabase bucket for snapshots (case-sensitive)
INTENTWATCH_SNAPSHOT_BUCKET=Snapshots

# ---------------- Weapon alert tuning ----------------
# Tighten/loosen weapon sensitivity
# INTENTWATCH_WEAPON_CONF=0.75
# INTENTWATCH_WEAPON_PERSIST_FRAMES=2

# Optional: verification weapon model (hybrid strategy)
# Use a fast model for live detection and a more accurate model for verification.
# The verify model runs only at Weapon event start, right before alert emission.
# INTENTWATCH_WEAPON_VERIFY_MODEL_PATH=
# Windows note (IMPORTANT): In `.env`, avoid quoted backslash paths like "D:\\...\\best.pt".
# Some dotenv parsers treat sequences like `\b` as escape codes, corrupting the path.
# Prefer forward slashes:
#   INTENTWATCH_WEAPON_MODEL_PATH=D:/intent-watch/runs_weapon/.../weights/best.pt
# INTENTWATCH_WEAPON_VERIFY_CONF=0.85
# INTENTWATCH_WEAPON_VERIFY_IMGSZ=800
# INTENTWATCH_WEAPON_VERIFY_COOLDOWN_SECONDS=2.0
# If verification sometimes misses real weapons, allow quick re-tries for a short window.
# INTENTWATCH_WEAPON_VERIFY_RETRY_SECONDS=0.4
# INTENTWATCH_WEAPON_VERIFY_WINDOW_SECONDS=1.5

# Prevent repeated weapon notifications while the weapon stays visible
# INTENTWATCH_WEAPON_REARM_SECONDS=20
# INTENTWATCH_WEAPON_CLEAR_SECONDS=2

# Legacy / fallback weapon models (OFF by default to avoid false positives)
# INTENTWATCH_WEAPON_ALLOW_LEGACY_MODEL=0
# INTENTWATCH_WEAPON_ENABLE_FALLBACK=0

# Optional strict allowlist for weapon model class names.
# - If UNSET: no allowlist is enforced (recommended for custom/single-class weapon models).
# - If SET: only these labels (or their normalized aliases) are treated as weapon candidates.
# If you see false positives because your weapon model includes non-weapon classes, set this.
# INTENTWATCH_WEAPON_LABELS=pistol,knife,gun,rifle,weapon,firearm

# ---------------- Live camera / IP webcam ----------------
# If set, the UI "Start" button will use this IP Webcam URL instead of device 0.
# You can paste either a full URL or a host:port, e.g.:
#   INTENTWATCH_WEBCAM_URL=http://10.12.26.111:8080
#   INTENTWATCH_WEBCAM_URL=10.12.26.111:8080
# The backend will normalize it to the typical Android IP Webcam endpoint.
# INTENTWATCH_WEBCAM_URL=

# Low-latency mode for live cameras (recommended).
# When inference is slower than the camera FPS, the backend will drop stale frames
# and always process the most recent frame so labels/alerts don't appear "late".
INTENTWATCH_CAMERA_DROP_STALE_FRAMES=1

# Keep uploaded/local video files close to real-time.
# If inference is slower than the file FPS, the backend will skip frames instead of
# slowing down playback (prevents "late" labels/alerts when demoing with videos).
INTENTWATCH_FILE_REALTIME=1

# ---------------- Zones / High risk areas ----------------
# How long a person must remain inside a zone before an alert triggers.
# Lower = more real-time (can increase alerts); higher = fewer alerts.
# Default in code is 0.5 seconds.
# INTENTWATCH_ZONE_DWELL_SECONDS=0.5

# Minimum seconds between repeated zone alerts.
# INTENTWATCH_ZONE_COOLDOWN_SECONDS=10
